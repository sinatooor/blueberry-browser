# Pick a provider. Agent + Network Copilot + Chat all read these.
LLM_PROVIDER=anthropic

# Anthropic — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
# LLM_MODEL=claude-sonnet-4-6

# OpenAI — used when LLM_PROVIDER=openai (default if unset)
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini
# LLM_MODEL=gpt-4o-mini
